// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource sqlite {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int       @id @default(autoincrement())
  name             String    @default("")
  email            String    @unique @default("")
  password         String
  roles            String    @default("[]")
  createdAt        DateTime? @default(now())
  from_Review_user Review[]  @relation("Review_user")
}

model Company {
  id                  Int             @id @default(autoincrement())
  name                String          @default("")
  description         String          @default("")
  industry            String          @default("")
  trade               String          @default("")
  size                String
  collective          Boolean         @default(false)
  contact             String          @default("")
  hoursPerWeek        Int
  trainingShortenable Boolean         @default(false)
  partTime            Boolean         @default(false)
  trainingModels      TrainingModel[] @relation("Company_trainingModels")
  reviews             Review[]        @relation("Review_company")
  locations           String          @default("")
  link                String          @default("")
}

model TrainingModel {
  id        Int       @id @default(autoincrement())
  title     String    @default("")
  duration  String    @default("")
  companies Company[] @relation("Company_trainingModels")
}

model Review {
  id                     Int           @id @default(autoincrement())
  name                   String        @default("")
  user                   User?         @relation("Review_user", fields: [userId], references: [id])
  userId                 Int?          @map("user")
  publishName            Boolean       @default(false)
  gender                 String?
  company                Company?      @relation("Review_company", fields: [companyId], references: [id])
  companyId              Int?          @map("company")
  ageAtEmployment        Int
  genderOuted            Boolean       @default(false)
  position               String
  duration               String
  yearOfHiring           String        @default("")
  listenedTo             Boolean       @default(false)
  tone                   String?
  explained              String?
  canAskColleagues       Boolean       @default(false)
  canAskBoss             Boolean       @default(false)
  proximity              String?
  boundariesRespected    Boolean       @default(false)
  appreciated            String?
  experienceText         String        @default("")
  languages              String        @default("")
  socialGroups           SocialGroup[] @relation("Review_socialGroups")
  sharedWithCompany      String?
  feltComfortableSharing String?
  needsRespected         String?
  feedback               String        @default("")
  moreWishes             String        @default("")
  status                 String?       @default("draft")

  @@index([userId])
  @@index([companyId])
}

model SocialGroup {
  id                   Int      @id @default(autoincrement())
  name                 String   @unique @default("")
  recommendedByReviews Review[] @relation("Review_socialGroups")
}
